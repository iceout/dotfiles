[user]
	name = Zhang Xuanyi
	email = zhangxuanyi@tigerknows.com
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
	df = diff
	lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --
[color]
	diff = auto
	branch = auto
	log = auto
