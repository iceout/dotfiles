# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

zstyle ':zim:zmodule' use 'degit'
ZIM_HOME=~/.zim
# 检查路径是否在 PATH 中
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    # 如果路径不在 PATH 中，则添加到 PATH
    export PATH=$PATH:$HOME/.local/bin
fi

# dev tools managed by mise
{{- if eq .hostname "Winterfell" "Pentos-Int" "Pentos-M1" "Braavos" "Castle-Black" "Oldtown" "Volantis"}}
if [[ -x "$HOME/.local/bin/mise" ]]; then
    eval "$(~/.local/bin/mise activate zsh)"
fi
{{- end }}

# Download zimfw plugin manager if missing.
if [[ ! -e ${ZIM_HOME}/zimfw.zsh ]]; then
  mkdir -p ${ZIM_HOME} && wget -nv -O ${ZIM_HOME}/zimfw.zsh \
      https://github.com/zimfw/zimfw/releases/latest/download/zimfw.zsh
fi

# Install missing modules, and update ${ZIM_HOME}/init.zsh if missing or outdated.
if [[ ! ${ZIM_HOME}/init.zsh -nt ${ZDOTDIR:-${HOME}}/.zimrc ]]; then
  source ${ZIM_HOME}/zimfw.zsh init -q
fi

zstyle ':zim:git' aliases-prefix 'g'

source ${ZIM_HOME}/init.zsh

# 覆盖plugins/common-aliases/common-aliases.plugin.zsh
# [ -r ~/.ssh/config ] && _ssh_config=($(cat ~/.ssh/config | sed -ne 's/Host[=\t ]//p')) || _ssh_config=()
# zstyle ':completion:*:hosts' hosts $_ssh_config

# some export
if [[ -f ~/.bash_profile ]]; then
    source ~/.bash_profile
fi
if [ -f ~/.config/shell/aliases ]; then
    source ~/.config/shell/aliases
fi

# zoxide
if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init zsh)"
fi

{{- if ne .hostname "Braavos" }}
  {{- if ne .hostname "Winterfell" }}
  {{- if ne .hostname "Pentos-Int" }}
  {{- if ne .hostname "Pentos-M1" }}
  {{- if ne .hostname "Castle-Black" }}
  {{- if ne .hostname "Oldtown" }}
  {{- if ne .hostname "Volantis" }}
# nvm很慢，考虑更换其他工具
if [[ -n "$HOME/.nvm" && -d "$HOME/.nvm" ]]; then
    export NVM_DIR="$HOME/.nvm"
    zsh-defer source "$HOME/.nvm/nvm.sh"
fi
  {{- end }}
  {{- end }}
  {{- end }}
  {{- end }}
  {{- end }}
  {{- end }}
{{- end }}

# fzf
if [[ -t 0 && -t 1 ]] && command -v fzf >/dev/null 2>&1; then
    eval "$(fzf --zsh)"
elif [[ -t 0 && -t 1 && -f ~/.fzf.zsh ]]; then
    source ~/.fzf.zsh
fi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

bindkey -e

# Searching history with text already entered at prompt using up and down arrow
autoload -U up-line-or-beginning-search
autoload -U down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey "^[[A" up-line-or-beginning-search
bindkey "^[[B" down-line-or-beginning-search

# 使提示更清晰
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=cyan"

{{- if eq .chezmoi.os "darwin" }}
# iTerm2 shell integration is optional and only useful inside iTerm2.
if [[ "${TERM_PROGRAM:-}" == "iTerm.app" && -r "${HOME}/.iterm2_shell_integration.zsh" ]]; then
    source "${HOME}/.iterm2_shell_integration.zsh"
fi
{{- end }}

{{- if ne .hostname "Castle-Black" }}
  {{- if ne .hostname "Oldtown" }}
# direnv
if command -v direnv >/dev/null 2>&1; then
    eval "$(direnv hook zsh)"
fi
  {{- end }}
{{- end }}
